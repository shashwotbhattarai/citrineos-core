# =============================================================================
# Yatri Energy CitrineOS - Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Usage: docker compose up -d
#
# Prerequisites:
#   1. Login to Docker Hub: docker login -u YOUR_USERNAME
#   2. AWS RDS PostgreSQL with PostGIS extension
#   3. AWS S3 bucket for config storage

# =============================================================================
# DOCKER HUB CONFIGURATION (Required for private image)
# =============================================================================
DOCKERHUB_USERNAME=yatridockerhub

# =============================================================================
# AWS RDS POSTGRESQL CONFIGURATION
# =============================================================================
RDS_HOST=your-db.region.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=citrine
RDS_USERNAME=citrine
RDS_PASSWORD=your-password
RDS_SSL=true

# Connection Pool Settings
RDS_POOL_MAX=20
RDS_POOL_MIN=5
RDS_MAX_RETRIES=5
RDS_RETRY_DELAY=5000

# =============================================================================
# AWS S3 CONFIGURATION
# =============================================================================
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# =============================================================================
# YATRI ENERGY BACKEND INTEGRATION
# =============================================================================
YATRI_ENERGY_BASE_URL=https://api.dev.yatri-energy.yatrimotorcycle.com
YATRI_ENERGY_API_KEY=your-api-key
YATRI_ENERGY_TIMEOUT=10000
YATRI_MINIMUM_BALANCE=100.0
YATRI_WALLET_INTEGRATION_ENABLED=true

# =============================================================================
# RABBITMQ CONFIGURATION
# =============================================================================
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# =============================================================================
# HASURA CONFIGURATION
# =============================================================================
HASURA_DEV_MODE=false

# =============================================================================
# WATCHTOWER NOTIFICATIONS (Optional)
# =============================================================================
# Slack: slack://token-a/token-b/token-c
# Discord: discord://token@webhookid
# Telegram: telegram://token@telegram?chats=@channel
WATCHTOWER_NOTIFICATION_URL=
