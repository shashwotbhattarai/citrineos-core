# =============================================================================
# Yatri Energy CitrineOS - Bootstrap Environment Configuration
# =============================================================================
# Bootstrap fields (secrets, infrastructure, healthcheck deps) are configured here.
# Application behavior settings go in config.json (S3/local storage).
# See Server/src/config/config.json.example for system config template.
#
# All variables use BOOTSTRAP_ prefix to distinguish from system config.
# Usage: Copy to .env and fill in your values
#
# Decision rule:
#   Secret / credential / infrastructure / healthcheck dependency? -> here (.env)
#   Application behavior? -> config.json in storage
# =============================================================================

# =============================================================================
# DOCKER HUB CONFIGURATION (Required for private image)
# =============================================================================
BOOTSTRAP_DOCKERHUB_USERNAME=yatridockerhub
BOOTSTRAP_DOCKERHUB_TOKEN=

# =============================================================================
# AWS RDS POSTGRESQL CONFIGURATION
# =============================================================================
BOOTSTRAP_RDS_HOST=
BOOTSTRAP_RDS_PORT=5432
BOOTSTRAP_RDS_DATABASE=citrine
BOOTSTRAP_RDS_USERNAME=
BOOTSTRAP_RDS_PASSWORD=
BOOTSTRAP_RDS_SSL=true

# Connection Pool Settings
BOOTSTRAP_RDS_POOL_MAX=20
BOOTSTRAP_RDS_POOL_MIN=5
BOOTSTRAP_RDS_MAX_RETRIES=5
BOOTSTRAP_RDS_RETRY_DELAY=5000

# =============================================================================
# AWS S3/SQS CONFIGURATION
# =============================================================================
BOOTSTRAP_AWS_REGION=ap-south-1
BOOTSTRAP_S3_BUCKET_NAME=
BOOTSTRAP_AWS_ACCESS_KEY_ID=
BOOTSTRAP_AWS_SECRET_ACCESS_KEY=
BOOTSTRAP_YATRI_ENERGY_SQS_REGION=ap-south-1
BOOTSTRAP_YATRI_ENERGY_SQS_QUEUE_URL=

# =============================================================================
# API AUTHENTICATION (CitrineOS HTTP API)
# =============================================================================
# config.json sets authProvider.apiKey: true (which type), this is the actual secret
BOOTSTRAP_CITRINEOS_API_KEY=

# =============================================================================
# YATRI ENERGY BACKEND INTEGRATION (Bootstrap only - secrets & healthcheck)
# =============================================================================
# NOTE: timeout and minimumBalance are in config.json (system config), NOT here.
BOOTSTRAP_YATRI_ENERGY_BASE_URL=
BOOTSTRAP_YATRI_ENERGY_API_KEY=
BOOTSTRAP_YATRI_WALLET_INTEGRATION_ENABLED=true
BOOTSTRAP_YATRI_ENERGY_RABBITMQ_URL=
BOOTSTRAP_YATRI_ENERGY_RABBITMQ_EXCHANGE=citrineos

# =============================================================================
# INTERNAL RABBITMQ CONFIGURATION (CitrineOS message broker)
# =============================================================================
BOOTSTRAP_RABBITMQ_USER=guest
BOOTSTRAP_RABBITMQ_PASS=guest
BOOTSTRAP_AMQP_EXCHANGE=citrineos

# =============================================================================
# HASURA CONFIGURATION
# =============================================================================
BOOTSTRAP_HASURA_ADMIN_SECRET=
BOOTSTRAP_HASURA_DEV_MODE=false

# =============================================================================
# WATCHTOWER NOTIFICATIONS (Optional)
# =============================================================================
# Slack: slack://token-a/token-b/token-c
# Discord: discord://token@webhookid
# Telegram: telegram://token@telegram?chats=@channel
BOOTSTRAP_WATCHTOWER_NOTIFICATION_URL=
