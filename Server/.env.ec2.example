# =============================================================================
# Yatri Energy CitrineOS - EC2 Production Environment Configuration
# =============================================================================
# Copy this file to .env.ec2 and fill in your values
# Usage: docker compose -f docker-compose-ec2.yml --env-file .env.ec2 up -d

# =============================================================================
# DOCKER HUB CONFIGURATION (Required for private image)
# =============================================================================
DOCKERHUB_USERNAME=yatridockerhub
DOCKERHUB_TOKEN=
# =============================================================================
# AWS RDS POSTGRESQL CONFIGURATION
# =============================================================================
RDS_HOST=yatri-energy-test.cequlpfj9etm.ap-south-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=yatri-energy-citrine-test
RDS_USERNAME=yatri
RDS_PASSWORD=
RDS_SSL=true

# Connection Pool Settings
RDS_POOL_MAX=20
RDS_POOL_MIN=5
RDS_MAX_RETRIES=5
RDS_RETRY_DELAY=5000

# =============================================================================
# AWS S3 CONFIGURATION
# =============================================================================
AWS_REGION=ap-south-1
S3_BUCKET_NAME=yatri-energy-citrineos-test-files
AWS_ACCESS_KEY_ID=AKIA2ASWY2RH3JCT6XGM
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# YATRI ENERGY BACKEND INTEGRATION
# =============================================================================
YATRI_ENERGY_BASE_URL=https://api.dev.yatri-energy.yatrimotorcycle.com
YATRI_ENERGY_API_KEY=your-api-key
YATRI_ENERGY_TIMEOUT=10000
YATRI_MINIMUM_BALANCE=100.0
YATRI_WALLET_INTEGRATION_ENABLED=true

# =============================================================================
# RABBITMQ CONFIGURATION
# =============================================================================
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# =============================================================================
# HASURA CONFIGURATION
# =============================================================================
HASURA_DEV_MODE=false

# =============================================================================
# WATCHTOWER NOTIFICATIONS (Optional)
# =============================================================================
# Slack: slack://token-a/token-b/token-c
# Discord: discord://token@webhookid
# Telegram: telegram://token@telegram?chats=@channel
WATCHTOWER_NOTIFICATION_URL=