# =============================================================================
# AWS Configuration for CitrineOS (RDS + S3)
# =============================================================================
# Copy this file to .env.s3 and fill in your actual values
# Usage: docker compose -f docker-compose-s3.yml --env-file .env.s3 up -d
# =============================================================================

# =============================================================================
# REQUIRED: AWS RDS PostgreSQL Configuration
# =============================================================================

# RDS endpoint hostname (e.g., citrine-prod.abc123xyz.ap-south-1.rds.amazonaws.com)
RDS_HOST=your-rds-endpoint.region.rds.amazonaws.com

# Database credentials
RDS_USERNAME=citrine
RDS_PASSWORD=your-secure-password-here

# Database name
RDS_DATABASE=citrine

# Database port (default: 5432)
RDS_PORT=5432

# =============================================================================
# SSL CONFIGURATION (Required for AWS RDS)
# =============================================================================

# Enable SSL encryption for database connections
RDS_SSL=true

# =============================================================================
# REQUIRED: AWS S3 Configuration
# =============================================================================

# AWS Region (must match your S3 bucket region)
AWS_REGION=ap-south-1

# S3 bucket name for CitrineOS files (certificates, configs, etc.)
# Bucket will be auto-created if IAM permissions allow
S3_BUCKET_NAME=citrineos-files

# AWS credentials (required if not using IAM roles)
# If running on EC2 with IAM role, these can be left empty
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# =============================================================================
# Database Connection Pool Settings (for production tuning)
# =============================================================================

# Maximum number of connections in the pool (default: 20)
RDS_POOL_MAX=20

# Minimum number of connections in the pool (default: 5)
RDS_POOL_MIN=5

# Maximum connection retries on startup (default: 5)
RDS_MAX_RETRIES=5

# Delay between connection retries in milliseconds (default: 5000)
RDS_RETRY_DELAY=5000

# =============================================================================
# Yatri Energy Integration
# =============================================================================

YATRI_ENERGY_BASE_URL=https://api.dev.yatri-energy.yatrimotorcycle.com
YATRI_ENERGY_API_KEY=
YATRI_ENERGY_TIMEOUT=10000
YATRI_MINIMUM_BALANCE=100.0
YATRI_WALLET_INTEGRATION_ENABLED=true

# =============================================================================
# PREREQUISITES (Complete these before starting):
# =============================================================================
#
# 1. CREATE RDS INSTANCE with PostgreSQL 16+ or 17+
#
# 2. INSTALL POSTGIS EXTENSION (required for Location data):
#    Connect to RDS and run:
#    CREATE EXTENSION IF NOT EXISTS postgis;
#
# 3. CONFIGURE RDS SECURITY GROUP:
#    Allow inbound traffic on port 5432 from your deployment environment
#
# 4. CREATE S3 BUCKET (or let CitrineOS auto-create):
#    aws s3 mb s3://citrineos-files --region ap-south-1
#
# 5. CONFIGURE IAM PERMISSIONS for S3:
#    Required permissions: s3:GetObject, s3:PutObject, s3:CreateBucket
#
# 6. START SERVICES:
#    docker compose -f docker-compose-s3.yml --env-file .env.s3 up -d
#
# =============================================================================
# TROUBLESHOOTING:
# =============================================================================
#
# Error: "no pg_hba.conf entry... no encryption"
# Fix: Ensure RDS_SSL=true is set
#
# Error: "Unknown constraint error" during migration
# Fix: Install PostGIS extension on RDS
#
# Error: "Connection refused"
# Fix: Check RDS security group allows port 5432
#
# Error: "Access Denied" for S3
# Fix: Check AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are correct
#      Or ensure EC2 instance has IAM role with S3 permissions
#
# Error: "NoSuchBucket"
# Fix: Create the S3 bucket or ensure IAM has s3:CreateBucket permission
#
# =============================================================================
# SECURITY NOTES:
# =============================================================================
#
# - NEVER commit .env.s3 with real credentials to version control
# - Use AWS Secrets Manager for sensitive values in production
# - Keep RDS in private subnet with VPC security groups
# - Enable RDS encryption at rest
# - Use IAM roles instead of access keys when running on EC2
# - Enable S3 bucket versioning for data protection
# - Consider S3 bucket encryption (SSE-S3 or SSE-KMS)
#
# =============================================================================
